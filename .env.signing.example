# Top Focus — macOS Code Signing Environment Variables
# Copy this file to .env.signing and fill in real values when ready to sign.
#
# To obtain these values:
# 1. Join the Apple Developer Program ($99/year): https://developer.apple.com/programs/
# 2. Create a "Developer ID Application" certificate in Keychain Access or via Xcode
# 3. Find your Team ID at: https://developer.apple.com/account -> Membership Details
# 4. Create an app-specific password at: https://appleid.apple.com/account/manage -> App-Specific Passwords
#
# Tauri reads these during `tauri build`. For local dev (`tauri dev`), signing is skipped.
# When ready, update src-tauri/tauri.conf.json:
#   "signingIdentity": "Developer ID Application: Your Name (TEAMID)"
# replacing the current "-" (ad-hoc) placeholder.

# The signing certificate identity (from Keychain Access -> My Certificates)
# Format: "Developer ID Application: Your Name (TEAMID)"
APPLE_SIGNING_IDENTITY=

# Path to the .p12 certificate file (for CI/CD; local dev uses Keychain)
APPLE_CERTIFICATE=

# Password for the .p12 certificate file
APPLE_CERTIFICATE_PASSWORD=

# Apple ID email used for notarization
APPLE_ID=

# App-specific password for notarization (NOT your Apple ID password)
APPLE_PASSWORD=

# Your 10-character Apple Developer Team ID
APPLE_TEAM_ID=
